{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug executable 'tank_attack_rust'",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "run",
          "--bin=tank_attack_rust"
        ]
      },
      "args": []
    },
    {
      "name": "Debug unit tests in executable 'tank_attack_rust'",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": [
          "test",
          "--bin=tank_attack_rust"
        ]
      }
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "/home/myendeavour/Documents/Coding/rust/tank_attack_rust",
      "program": "/home/myendeavour/Documents/Coding/rust/tank_attack_rust/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}